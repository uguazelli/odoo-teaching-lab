<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="brand_form" model="ir.ui.view">
        <field name="name">brand.form</field>
        <field name="model">car.brand</field>
        <field name="arch" type="xml">
            <form string="Brand">
                <sheet>
                    <group>
                        <field name="name" />
                        <field name="country" />

                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="brand_tree" model="ir.ui.view">
        <field name="name">brand.list</field>
        <field name="model">car.brand</field>
        <field name="arch" type="xml">
            <list string="Brands">
                <field name="name" />
            </list>
        </field>
    </record>

    <record id="action_brand" model="ir.actions.act_window">
        <field name="name">Brands</field>
        <field name="res_model">car.brand</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Add a brand</p>
        </field>

    </record>
</odoo>