<?xml version="1.0" encoding="UTF-8"?>

<odoo>

    <record id="car_tree" model="ir.ui.view">
        <field name="name">car.list</field>
        <field name="model">car.car</field>
        <field name="arch" type="xml">
            <list string="Cars">
                <field name="full_name" />
                <field name="model" />
                <field name="year" />
                <field name="price" />
            </list>
        </field>
    </record>

    <record id="car_form" model="ir.ui.view">
        <field name="name">car.form</field>
        <field name="model">car.car</field>
        <field name="arch" type="xml">
            <form string="Car">
                <header>
                    <field
                        name="status"
                        widget="statusbar"
                        statusbar_visible="draft,available,reserved,sold,cancelled" />

                    <button
                        name="sell_car"
                        type="object"
                        string="Mark as Sold"
                        class="oe_highlight"
                        invisible="status == 'sold'" />

                    <button
                        name="set_status_draft"
                        type="object"
                        string="Mark as Draft"
                        invisible="status == 'draft'" />

                    <button
                        name="set_status_available"
                        type="object"
                        string="Mark as Available"
                        invisible="status == 'available'" />

                    <button
                        name="set_status_reserved"
                        type="object"
                        string="Mark as Reserved"
                        invisible="status == 'reserved'" />

                    <button
                        name="set_status_cancelled"
                        type="object"
                        string="Mark as Cancelled"
                        invisible="status == 'cancelled'" />
                </header>
                <sheet>
                    <group>
                        <field name="full_name" />
                        <field name="name" />
                        <field name="status" />
                        <field name="brand_id" />
                        <field name="brand_country" />
                        <field name="model" />
                        <field name="available" />
                    </group>
                    <group>
                        <field name="feature_ids" widget="many2many_tags" />
                        <field name="year" />
                        <field name="price" />
                        <field name="buyer_id"
                            domain="[('max_budget', '>=', price)]"
                            context="{'default_max_budget': price}"
                        />
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_car" model="ir.actions.act_window">
        <field name="name">Cars</field>
        <field name="res_model">car.car</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Add a car</p>
        </field>
    </record>

</odoo>